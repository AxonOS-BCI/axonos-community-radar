{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://axonos-bci.github.io/axonos-community-radar/data/radar.schema.json",
  "title": "AxonOS Radar dataset",
  "description": "Public data contract for data/radar.json. Derived only from public GitHub metadata. Inclusion is not endorsement; scores are discovery signals, not quality, safety, or clinical ratings.",
  "type": "object",
  "required": [
    "version",
    "generated_at",
    "counts",
    "projects"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "enum": [
        2,
        3,
        4,
        5
      ]
    },
    "generated_at": {
      "type": "string"
    },
    "snapshot_at": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "criteria": {
      "type": "string"
    },
    "refresh": {
      "type": "string"
    },
    "min_stars": {
      "type": "integer",
      "minimum": 0
    },
    "topics_failed": {
      "type": "integer",
      "minimum": 0
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "methodology": {
      "type": "object"
    },
    "counts": {
      "type": "object",
      "required": [
        "total"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "active_30d": {
          "type": "integer",
          "minimum": 0
        },
        "new": {
          "type": "integer",
          "minimum": 0
        },
        "rising": {
          "type": "integer",
          "minimum": 0
        },
        "builders": {
          "type": "integer",
          "minimum": 0
        },
        "health_strong": {
          "type": "integer",
          "minimum": 0
        },
        "health_median": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "interop_tagged": {
          "type": "integer",
          "minimum": 0
        },
        "foundation_checked": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/project"
      }
    },
    "builders": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/builder"
      }
    },
    "ecosystem": {
      "type": "object"
    },
    "ecosystem_count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "project": {
      "type": "object",
      "required": [
        "full_name",
        "html_url",
        "category"
      ],
      "properties": {
        "full_name": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "html_url": {
          "type": "string",
          "pattern": "^https://github\\.com/[^/]+/[^/]+"
        },
        "description": {
          "type": "string",
          "maxLength": 240
        },
        "stars": {
          "type": "integer",
          "minimum": 0
        },
        "forks": {
          "type": "integer",
          "minimum": 0
        },
        "language": {
          "type": "string"
        },
        "license": {
          "type": [
            "string",
            "null"
          ]
        },
        "has_license": {
          "type": "boolean"
        },
        "pushed_at": {
          "type": "string"
        },
        "days_since_push": {
          "type": "integer",
          "minimum": 0
        },
        "topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "evidence_tier": {
          "type": "string",
          "enum": [
            "L3_EXPLICIT_BCI",
            "L2_NEURAL_SIGNAL",
            "L1_CONTEXT_PLUS_NEURO",
            "L0_WEAK_ADJACENT"
          ]
        },
        "inclusion_reason": {
          "type": "string",
          "minLength": 1
        },
        "matched_topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "matched_keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "quality_flags": {
          "type": "object",
          "properties": {
            "possible_false_positive": {
              "type": "boolean"
            },
            "low_metadata": {
              "type": "boolean"
            },
            "missing_license": {
              "type": "boolean"
            },
            "no_recent_activity": {
              "type": "boolean"
            },
            "unclear_license": {
              "type": "boolean"
            },
            "no_description": {
              "type": "boolean"
            },
            "no_topics": {
              "type": "boolean"
            },
            "stale_365d": {
              "type": "boolean"
            }
          }
        },
        "first_seen": {
          "type": "string"
        },
        "is_new": {
          "type": "boolean"
        },
        "active": {
          "type": "boolean"
        },
        "stars_delta_7d": {
          "type": "integer"
        },
        "stars_delta_30d": {
          "type": "integer"
        },
        "rising": {
          "type": "boolean"
        },
        "axon_relevance": {
          "type": "object"
        },
        "_score": {
          "type": "number"
        },
        "updated_at": {
          "type": "string"
        },
        "falling": {
          "type": "boolean"
        },
        "community_active": {
          "type": "boolean"
        },
        "activity_pending": {
          "type": "boolean"
        },
        "ecosystem": {
          "type": "boolean"
        },
        "ecosystem_role": {
          "type": "string"
        },
        "ecosystem_note": {
          "type": "string"
        },
        "ecosystem_group": {
          "type": "string"
        },
        "signals": {
          "$ref": "#/$defs/signals"
        },
        "interop": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{0,23}$"
          },
          "description": "Interop tags detected from topics/description/homepage against data/interop-vocab.json (heuristic; v6)."
        },
        "foundation": {
          "type": "object",
          "description": "Foundation signals (v6): checkable repo facts only — community profile files, root CITATION.cff, root SECURITY.md, CI workflows.",
          "required": [
            "license_file",
            "readme",
            "contributing",
            "code_of_conduct",
            "citation",
            "security_policy",
            "ci",
            "count"
          ],
          "properties": {
            "license_file": {
              "type": "boolean"
            },
            "readme": {
              "type": "boolean"
            },
            "contributing": {
              "type": "boolean"
            },
            "code_of_conduct": {
              "type": "boolean"
            },
            "citation": {
              "type": "boolean"
            },
            "security_policy": {
              "type": "boolean"
            },
            "ci": {
              "type": "boolean"
            },
            "health_pct": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0,
              "maximum": 100
            },
            "count": {
              "type": "integer",
              "minimum": 0,
              "maximum": 7
            }
          }
        }
      }
    },
    "builder": {
      "type": "object",
      "required": [
        "owner",
        "html_url",
        "project_count"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "html_url": {
          "type": "string",
          "pattern": "^https://github\\.com/"
        },
        "project_count": {
          "type": "integer",
          "minimum": 1
        },
        "total_stars": {
          "type": "integer",
          "minimum": 0
        },
        "active_projects_30d": {
          "type": "integer",
          "minimum": 0
        },
        "top_categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "top_languages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "projects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "owner_type": {
          "type": "string"
        },
        "followers": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "signals": {
      "type": "object",
      "description": "Ecosystem Health Signals: 0-100 sub-scores computed only from public GitHub metadata (see docs/METHODOLOGY.md). Dimensions absent from inputs are omitted rather than zeroed.",
      "required": [
        "overall",
        "basis"
      ],
      "properties": {
        "overall": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "basis": {
          "type": "string",
          "enum": [
            "enriched",
            "partial",
            "search-only"
          ]
        },
        "license": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "maintenance": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "momentum": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "adoption": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "team": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "docs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "badges": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
